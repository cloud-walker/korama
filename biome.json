{
	"$schema": "https://biomejs.dev/schemas/2.1.4/schema.json",
	"formatter": {
		"bracketSpacing": false
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"assist": {"actions": {"source": {"organizeImports": "on"}}},
	"javascript": {
		"formatter": {
			"semicolons": "asNeeded"
		}
	},
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": ["*.{js,ts}", "apps/**/*.{ts,tsx}", "packages/**/*.{ts,tsx}"]
	}
}
