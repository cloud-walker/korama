{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"formatter": {
		"bracketSpacing": false
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"assist": {"actions": {"source": {"organizeImports": "on"}}},
	"javascript": {
		"formatter": {
			"semicolons": "asNeeded"
		}
	},
	"files": {
		"includes": [
			"*.{js,ts}",
			"apps/**/*.{ts,tsx}",
			"packages/**/*.{ts,tsx}",
			"!**/{styled-system,.react-router,dist}"
		]
	}
}
