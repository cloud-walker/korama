{
	"name": "korama",
	"private": true,
	"scripts": {
		"build": "turbo build",
		"dev": "turbo dev",
		"lint": "biome check . && turbo lint",
		"check-types": "turbo check-types",
		"format": "biome format --write .",
		"test": "turbo test",
		"coverage": "turbo coverage",
		"health": "turbo build && fallow",
		"release": "changeset publish"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"fallow": "^2.74.0",
		"playwright": "^1.60.0",
		"turbo": "^2.9.14",
		"typescript": "~6.0.3"
	},
	"packageManager": "pnpm@11.1.2",
	"engines": {
		"node": ">=20"
	},
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": "24.14.1",
			"onFail": "download"
		}
	},
	"dependencies": {
		"@changesets/cli": "^2.31.0"
	},
	"pnpm": {
		"overrides": {
			"minimatch": ">=10.2.3",
			"rollup": ">=4.59.0",
			"ajv": ">=8.18.0",
			"js-yaml": ">=3.14.2 <4",
			"qs": ">=6.14.1",
			"path-to-regexp": ">=0.1.13",
			"picomatch": ">=4.0.4",
			"hono": ">=4.12.12",
			"@hono/node-server": ">=1.19.13",
			"lodash": ">=4.18.0"
		}
	}
