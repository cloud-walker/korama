{
	"name": "@korama/react",
	"version": "0.1.3",
	"type": "module",
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"check-types": "tsc",
		"lint": "publint --strict && attw --profile esm-only --pack .",
		"build": "tsdown",
		"test": "vitest run --browser.headless",
		"coverage": "vitest run --browser.headless --coverage"
	},
	"exports": {
		".": {
			"types": "./dist/main.d.mts",
			"default": "./dist/main.mjs"
		}
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/browser-playwright": "^4.1.5",
		"@vitest/coverage-v8": "^4.1.5",
		"publint": "^0.3.20",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"tsdown": "^0.21.10",
		"typescript": "~6.0.3",
		"vitest": "^4.1.5",
		"vitest-browser-react": "^2.2.0"
	},
	"peerDependencies": {
		"react": "^19.1.0"
	},
	"dependencies": {
		"zod": "^4.4.3"
	}
}
