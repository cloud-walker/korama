{
	"name": "@korama/core",
	"version": "0.0.0",
	"type": "module",
	"publishConfig": {
		"access": "public"
	},
	"files": ["dist"],
	"exports": {
		".": {
			"types": "./dist/main.d.mts",
			"default": "./dist/main.mjs"
		},
		"./panda": {
			"types": "./dist/panda.d.mts",
			"default": "./dist/panda.mjs"
		}
	},
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc",
		"lint": "publint --strict && attw --profile esm-only --pack ."
	},
	"dependencies": {
		"@pandacss/dev": "^1.11.1"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.2",
		"publint": "^0.3.21",
		"tsdown": "^0.22.0",
		"typescript": "~6.0.3"
	}
}
